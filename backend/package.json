{
  "name": "notes-app-backend",
  "version": "1.0.0",
  "description": "Notes app backend — Express + TypeScript + SQLite",
  "scripts": {
    "dev":     "tsx watch --experimental-sqlite src/index.ts",
    "build":   "tsc",
    "start":   "node --experimental-sqlite dist/index.js",
    "test":    "node --experimental-sqlite --no-warnings --require ./tests/setup.cjs --require tsx/cjs tests/notes.test.ts",
    "lint":    "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.19",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  }
}
