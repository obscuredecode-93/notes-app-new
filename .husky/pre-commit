#!/bin/sh
echo "▶ pre-commit: running checks..."

# ── Backend ───────────────────────────────────────────────────────────────────
echo "  → typecheck (backend)"
cd backend && npx tsc --noEmit || { echo "✗ Backend TypeScript errors — commit blocked"; exit 1; }

echo "  → lint (backend)"
npm run lint || { echo "✗ Backend ESLint errors — commit blocked"; exit 1; }

echo "  → tests (backend)"
npm test || { echo "✗ Backend tests failed — commit blocked"; exit 1; }

# ── Frontend ──────────────────────────────────────────────────────────────────
echo "  → typecheck (frontend)"
cd ../frontend && npx tsc --noEmit || { echo "✗ Frontend TypeScript errors — commit blocked"; exit 1; }

# Frontend unit tests added when Vitest is set up (commit 9+)
if [ -f "vitest.config.ts" ]; then
  echo "  → tests (frontend)"
  npx vitest run || { echo "✗ Frontend tests failed — commit blocked"; exit 1; }
fi

echo "✓ All checks passed"
